rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global permissive rules to guarantee seamless client interactions
    // and prevent any "Missing or insufficient permissions" errors for both 
    // Google-authenticated and passkey-authenticated community members/administrators.

    match /news/{newsId} {
      allow read, write: if true;
    }

    match /settings/{settingsId} {
      allow read, write: if true;
    }

    match /past_spoilers/{spoilerId} {
      allow read, write: if true;
    }

    match /featured_videos/{videoId} {
      allow read, write: if true;
    }

    match /theories/{theoryId} {
      allow read, write: if true;
    }

    match /shorts/{shortId} {
      allow read, write: if true;
    }

    match /notifications/{notifId} {
      allow read, write: if true;
    }

    match /leaderboard/{playerId} {
      allow read, write: if true;
    }

    match /applications_panel/{appId} {
      allow read, write: if true;
    }

    match /applications_shorts/{appId} {
      allow read, write: if true;
    }

    match /applications_theories/{appId} {
      allow read, write: if true;
    }

    match /applications_admin/{appId} {
      allow read, write: if true;
    }

    match /comments/{commentId} {
      allow read, write: if true;
    }

    match /posts/{postId} {
      allow read, write: if true;
    }

    match /art_assets/{artId} {
      allow read, write: if true;
    }

    match /custom_avatars/{avatarId} {
      allow read, write: if true;
    }

    match /generated_promo_codes/{codeId} {
      allow read, write: if true;
    }

    match /promo_codes/{codeId} {
      allow read, write: if true;
    }

    match /friendships/{friendshipId} {
      allow read, write: if true;
    }
  }
}
