rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailAdmin() {
      return request.auth != null 
             && request.auth.token != null 
             && request.auth.token.email != null 
             && (request.auth.token.email == "kawanyuri35@gmail.com" || request.auth.token.email == "eukoosh@gmail.com");
    }

    function isAdmin() {
      return isEmailAdmin()
             || (request.resource != null && request.resource.data != null && 'admin_secret' in request.resource.data && request.resource.data.admin_secret == "pkxd2026_super_secret_admin_key");
    }

    function isDeletable() {
      return isEmailAdmin()
             || (resource != null && resource.data != null && 'admin_secret' in resource.data && resource.data.admin_secret == "pkxd2026_super_secret_admin_key");
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // News rules
    match /news/{newsId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isDeletable();
    }

    // AppSettings rules
    match /settings/{settingsId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isDeletable();
    }

    // PastSpoiler rules
    match /past_spoilers/{spoilerId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (incoming().diff(existing()).affectedKeys().hasOnly(['ratingSum', 'ratingCount']))
                    || (incoming().diff(existing()).affectedKeys().hasOnly(['reactions']));
      allow delete: if isDeletable();
    }

    // Featured Videos rules
    match /featured_videos/{videoId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isDeletable();
    }

    // Theories rules
    match /theories/{theoryId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && incoming().likes == existing().likes + 1);
      allow delete: if isDeletable();
    }

    // Shorts rules
    match /shorts/{shortId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isDeletable();
    }

    // Notifications rules
    match /notifications/{notifId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isDeletable();
    }

    // Leaderboard rules
    match /leaderboard/{playerId} {
      allow read: if true;
      allow create, update: if (isSignedIn() && request.auth.uid == playerId)
                               || (request.resource != null && request.resource.data != null && 'admin_secret' in request.resource.data && request.resource.data.admin_secret == "pkxd2026_super_secret_admin_key");
      allow delete: if isDeletable();
    }

    // Applications rules
    match /applications_panel/{appId} {
      allow read, write: if true;
    }
    match /applications_shorts/{appId} {
      allow read, write: if true;
    }
    match /applications_theories/{appId} {
      allow read, write: if true;
    }
    match /applications_admin/{appId} {
      allow read, write: if true;
    }

    // Comments rules
    match /comments/{commentId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isDeletable();
    }
  }
}
