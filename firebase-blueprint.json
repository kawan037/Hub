{
  "entities": {
    "News": {
      "title": "News Item",
      "description": "A news or spoiler post on PK XD Central",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["spoilers", "updates", "codes", "events"] },
        "imageUrl": { "type": "string" },
        "date": { "type": "string" },
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "excerpt", "content", "category", "date", "author"]
    },
    "AppSettings": {
      "title": "Application Settings",
      "description": "Global settings for PK XD Central",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "spoilerTitle": { "type": "string" },
        "spoilerDesc": { "type": "string" },
        "adminPasskey": { "type": "string" }
      },
      "required": ["logoUrl", "spoilerTitle", "spoilerDesc", "adminPasskey"]
    },
    "PastSpoiler": {
      "title": "Past Spoiler",
      "description": "A historic spoiler published on PK XD Central",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "description", "createdAt"]
    },
    "FeaturedVideo": {
      "title": "Featured Video",
      "description": "Highlight gameplay or panel video",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["game_highlight", "panel_video"] },
        "author": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "youtubeUrl", "type", "createdAt"]
    },
    "Theory": {
      "title": "Theory",
      "description": "A fan-contributed or admin theory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "likes": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "content", "author", "likes", "createdAt"]
    },
    "ShortItem": {
      "title": "Short Item",
      "description": "A short format YouTube video item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "youtubeUrl", "createdAt"]
    },
    "Notification": {
      "title": "Notification Log",
      "description": "Notification log sent from administrators",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["story_published", "countdown_alert", "custom_push", "delayed_alert"] },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "body", "type", "createdAt"]
    },
    "LeaderboardPlayer": {
      "title": "Leaderboard Player",
      "description": "A real user profile for tracking XP and Flames",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "level": { "type": "number" },
        "xp": { "type": "number" },
        "flames": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "level", "xp", "flames", "updatedAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User feedback or discussion comment on a theory or video",
      "type": "object",
      "properties": {
        "targetId": { "type": "string" },
        "targetType": { "type": "string" },
        "authorName": { "type": "string" },
        "authorId": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["approved", "pending_review"] },
        "createdAt": { "type": "number" }
      },
      "required": ["targetId", "targetType", "authorName", "content", "status", "createdAt"]
    },
    "ApplicationPanel": {
      "title": "Video application highlight",
      "description": "Form submission to highlight a gameplay/panel video",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "submittedBy": { "type": "string" },
        "submittedByEmail": { "type": "string" },
        "createdAt": { "type": "number" },
        "status": { "type": "string" },
        "creator": { "type": "string" },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "social": { "type": "string" }
      },
      "required": ["id", "submittedBy", "submittedByEmail", "createdAt", "status", "creator", "url", "description"]
    },
    "ApplicationShorts": {
      "title": "Shorts application highlight",
      "description": "Form submission to highlight a YouTube short",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "submittedBy": { "type": "string" },
        "submittedByEmail": { "type": "string" },
        "createdAt": { "type": "number" },
        "status": { "type": "string" },
        "creator": { "type": "string" },
        "url": { "type": "string" },
        "title": { "type": "string" }
      },
      "required": ["id", "submittedBy", "submittedByEmail", "createdAt", "status", "creator", "url", "title"]
    },
    "ApplicationTheory": {
      "title": "Theory application highlight",
      "description": "Form submission to suggest/share a fan theory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "submittedBy": { "type": "string" },
        "submittedByEmail": { "type": "string" },
        "createdAt": { "type": "number" },
        "status": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" }
      },
      "required": ["id", "submittedBy", "submittedByEmail", "createdAt", "status", "title", "content", "author"]
    },
    "ApplicationAdmin": {
      "title": "Administrator role application",
      "description": "Form submission for applying for moderator/admin role",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "submittedBy": { "type": "string" },
        "submittedByEmail": { "type": "string" },
        "createdAt": { "type": "number" },
        "status": { "type": "string" },
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "age": { "type": "string" },
        "reason": { "type": "string" },
        "hours": { "type": "string" }
      },
      "required": ["id", "submittedBy", "submittedByEmail", "createdAt", "status", "name", "contact", "age", "reason", "hours"]
    },
    "Post": {
      "title": "Community Post",
      "description": "A social network post published by a fan on PK XD Central",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorName": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "likes": { "type": "number" },
        "likedBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "authorName", "authorId", "content", "likes", "createdAt"]
    },
    "GeneratedPromoCode": {
      "title": "Generated Promo Code",
      "description": "An in-app promo code created by admin with redeem limits",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "gems": { "type": "number" },
        "coins": { "type": "number" },
        "maxRedeems": { "type": "number" },
        "currentRedeems": { "type": "number" },
        "createdAt": { "type": "number" },
        "redeemedUsers": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["code", "gems", "coins", "maxRedeems", "currentRedeems", "createdAt", "redeemedUsers"]
    }
  },
  "firestore": {
    "/generated_promo_codes/{codeId}": {
      "schema": "GeneratedPromoCode",
      "description": "Collection of generated promo codes with redeem limits"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of social posts shared by users on PK XD Central"
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "Collection of community news and updates"
    },
    "/settings/{settingsId}": {
      "schema": "AppSettings",
      "description": "Global application configuration settings"
    },
    "/past_spoilers/{spoilerId}": {
      "schema": "PastSpoiler",
      "description": "Collection of past spoilers published on the site"
    },
    "/featured_videos/{videoId}": {
      "schema": "FeaturedVideo",
      "description": "Collection of featured homepage videos"
    },
    "/theories/{theoryId}": {
      "schema": "Theory",
      "description": "Collection of theories about PK XD"
    },
    "/shorts/{shortId}": {
      "schema": "ShortItem",
      "description": "Collection of curated community YouTube shorts"
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "Collection of push notification logs"
    },
    "/leaderboard/{playerId}": {
      "schema": "LeaderboardPlayer",
      "description": "Collection of real-player leaderboard stats"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments and replies on theories or videos"
    },
    "/applications_panel/{appId}": {
      "schema": "ApplicationPanel",
      "description": "Submission requests for Panel Video highlighting"
    },
    "/applications_shorts/{appId}": {
      "schema": "ApplicationShorts",
      "description": "Submission requests for YouTube Shorts highlighting"
    },
    "/applications_theories/{appId}": {
      "schema": "ApplicationTheory",
      "description": "Submission requests for PK XD Theory publication"
    },
    "/applications_admin/{appId}": {
      "schema": "ApplicationAdmin",
      "description": "Form requests for new admin recruitment candidacies"
    }
  }
}
